"""
hanna_barbera_characters.py
All major Hanna-Barbera cartoon characters for CartoonPal.

Hanna-Barbera Productions was founded in 1957 by William Hanna and Joseph Barbera
after MGM closed its animation division. The studio pioneered limited animation
for television and produced some of the most iconic characters in cartoon history.

All characters are currently owned by Warner Bros. Discovery following the chain:
Hanna-Barbera (1957) → Turner Broadcasting (1989) → Time Warner (1996) → Warner Bros. Discovery (2022)

Usage:
    from hanna_barbera_characters import add_hanna_barbera_characters
    add_hanna_barbera_characters(lib)
"""

from cartoon_system import (
    Cartoon, Creator, ProductionCompany,
    Series, OwnershipRecord, Era, Library
)

# ── Shared objects ────────────────────────────────────────────────────────────
HB = ProductionCompany("Hanna-Barbera Productions", 1957, still_active=False)
HANNA = Creator("William Hanna", "Co-founder, director & producer", 1910, 2001)
BARBERA = Creator("Joseph Barbera", "Co-founder, animator & story artist", 1911, 2006)

HB_OWNERSHIP = [
    ("Hanna-Barbera Productions", 1957, 1989, "original creation"),
    ("Turner Broadcasting System", 1989, 1996, "acquisition of Hanna-Barbera"),
    ("Time Warner / Warner Bros.", 1996, 2022, "Turner-Time Warner merger"),
    ("Warner Bros. Discovery", 2022, None, "corporate merger"),
]


def _hb_cartoon(name, description, character_type, debut_year,
                series_list, eras, wiki_slug, origin_note="Hollywood, California, USA — Hanna-Barbera Productions studio"):
    """Factory function to build a standard Hanna-Barbera cartoon record."""
    c = Cartoon(
        name=name,
        description=description,
        character_type=character_type,
        country_of_origin="USA",
        debut_year=debut_year,
    )
    c.original_studio = HB
    c.add_creator(HANNA)
    c.add_creator(BARBERA)

    for s in series_list:
        c.add_series(s)

    for i, (owner, yr_start, yr_end, method) in enumerate(HB_OWNERSHIP):
        is_current = (i == len(HB_OWNERSHIP) - 1)
        c.add_ownership_record(
            OwnershipRecord(owner, yr_start, yr_end, method, is_current_owner=is_current)
        )

    for era in eras:
        c.add_era(era)

    c.wiki_url = f"https://en.wikipedia.org/wiki/{wiki_slug}"
    c.origin_location = origin_note
    return c


