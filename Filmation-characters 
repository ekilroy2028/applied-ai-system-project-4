def _dic(name, description, character_type, debut_year,
        extra_creators, series_list, eras, wiki_slug,
        origin="Los Angeles, California, USA — DIC Entertainment"):
    c = Cartoon(name=name, description=description,
                character_type=character_type,
                country_of_origin="USA", debut_year=debut_year)
    c.original_studio = DIC_STUDIO
    c.add_creator(JEAN_CHALOPIN)
    c.add_creator(ANDY_HEYWARD)
    for ec in extra_creators:
        c.add_creator(ec)
    for s in series_list:
        c.add_series(s)
    for i, rec in enumerate(DIC_OWNERSHIP):
        is_cur = (i == len(DIC_OWNERSHIP) - 1)
        c.add_ownership_record(OwnershipRecord(rec[0], rec[1], rec[2], rec[3], is_current_owner=is_cur))
    for era in eras:
        c.add_era(era)
    c.wiki_url = f"https://en.wikipedia.org/wiki/{wiki_slug}"
    c.origin_location = origin
    return c
 
 
