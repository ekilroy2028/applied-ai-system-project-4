<h1 data-section-id="815tgq" data-start="4698" data-end="4742"><span role="text">✅ 3. ADD TEST FILE: <code data-start="4720" data-end="4742">tests/test_pawpal.py</code></span></h1>
<p data-start="4744" data-end="4777">Create a folder <code data-start="4760" data-end="4768">tests/</code> and add:</p>
<pre class="overflow-visible! px-0!" data-start="4779" data-end="6024"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#e45ab3" fill="currentColor"></use></svg>Python</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#ce3544" fill="currentColor"></use></svg></button><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost border-token-border-default ms-2 border font-sans" aria-label="Run code" type="button"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-lbtco6v1.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 361px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼk ͼy"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼn">from</span><span> </span><span class="ͼt">pawpal_system</span><span> </span><span class="ͼn">import</span><span> </span><span class="ͼt">Task</span><span>, </span><span class="ͼt">Pet</span><span>, </span><span class="ͼt">Owner</span><span>, </span><span class="ͼt">Scheduler</span><br><br><br><span class="ͼn">def</span><span> </span><span class="ͼt">test_task_completion</span><span>():</span><br><span>    </span><span class="ͼt">task</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"Feed"</span><span>, </span><span class="ͼr">"08:00"</span><span>)</span><br><span>    </span><span class="ͼt">task</span><span class="ͼn">.</span><span>mark_complete()</span><br><span>    </span><span class="ͼn">assert</span><span> </span><span class="ͼt">task</span><span class="ͼn">.</span><span>completed </span><span class="ͼn">is</span><span> </span><span class="ͼq">True</span><br><br><br><span class="ͼn">def</span><span> </span><span class="ͼt">test_add_task_to_pet</span><span>():</span><br><span>    </span><span class="ͼt">pet</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Pet</span><span>(</span><span class="ͼr">"Bella"</span><span>, </span><span class="ͼr">"Dog"</span><span>)</span><br><span>    </span><span class="ͼt">task</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"Walk"</span><span>, </span><span class="ͼr">"09:00"</span><span>)</span><br><span>    </span><span class="ͼt">pet</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">task</span><span>)</span><br><span>    </span><span class="ͼn">assert</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">pet</span><span class="ͼn">.</span><span>tasks) </span><span class="ͼn">==</span><span> </span><span class="ͼq">1</span><br><br><br><span class="ͼn">def</span><span> </span><span class="ͼt">test_sorting</span><span>():</span><br><span>    </span><span class="ͼt">owner</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Owner</span><span>(</span><span class="ͼr">"Test"</span><span>)</span><br><span>    </span><span class="ͼt">pet</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Pet</span><span>(</span><span class="ͼr">"Doggo"</span><span>, </span><span class="ͼr">"Dog"</span><span>)</span><br><span>    </span><span class="ͼt">pet</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"B"</span><span>, </span><span class="ͼr">"10:00"</span><span>))</span><br><span>    </span><span class="ͼt">pet</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"A"</span><span>, </span><span class="ͼr">"08:00"</span><span>))</span><br><span>    </span><span class="ͼt">owner</span><span class="ͼn">.</span><span>add_pet(</span><span class="ͼt">pet</span><span>)</span><br><br><span>    </span><span class="ͼt">scheduler</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Scheduler</span><span>()</span><br><span>    </span><span class="ͼt">tasks</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">scheduler</span><span class="ͼn">.</span><span>sort_by_time(</span><span class="ͼt">owner</span><span class="ͼn">.</span><span>get_all_tasks())</span><br><br><span>    </span><span class="ͼn">assert</span><span> </span><span class="ͼt">tasks</span><span>[</span><span class="ͼq">0</span><span>][</span><span class="ͼq">1</span><span>]</span><span class="ͼn">.</span><span>time </span><span class="ͼn">==</span><span> </span><span class="ͼr">"08:00"</span><br><br><br><span class="ͼn">def</span><span> </span><span class="ͼt">test_conflicts</span><span>():</span><br><span>    </span><span class="ͼt">owner</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Owner</span><span>(</span><span class="ͼr">"Test"</span><span>)</span><br><span>    </span><span class="ͼt">pet1</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Pet</span><span>(</span><span class="ͼr">"A"</span><span>, </span><span class="ͼr">"Dog"</span><span>)</span><br><span>    </span><span class="ͼt">pet2</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Pet</span><span>(</span><span class="ͼr">"B"</span><span>, </span><span class="ͼr">"Cat"</span><span>)</span><br><br><span>    </span><span class="ͼt">pet1</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"Walk"</span><span>, </span><span class="ͼr">"08:00"</span><span>))</span><br><span>    </span><span class="ͼt">pet2</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"Feed"</span><span>, </span><span class="ͼr">"08:00"</span><span>))</span><br><br><span>    </span><span class="ͼt">owner</span><span class="ͼn">.</span><span>add_pet(</span><span class="ͼt">pet1</span><span>)</span><br><span>    </span><span class="ͼt">owner</span><span class="ͼn">.</span><span>add_pet(</span><span class="ͼt">pet2</span><span>)</span><br><br><span>    </span><span class="ͼt">scheduler</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Scheduler</span><span>()</span><br><span>    </span><span class="ͼt">conflicts</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">scheduler</span><span class="ͼn">.</span><span>detect_conflicts(</span><span class="ͼt">owner</span><span class="ͼn">.</span><span>get_all_tasks())</span><br><br><span>    </span><span class="ͼn">assert</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">conflicts</span><span>) </span><span class="ͼn">==</span><span> </span><span class="ͼq">1</span><br><br><br><span class="ͼn">def</span><span> </span><span class="ͼt">test_recurrence</span><span>():</span><br><span>    </span><span class="ͼt">pet</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Pet</span><span>(</span><span class="ͼr">"Bella"</span><span>, </span><span class="ͼr">"Dog"</span><span>)</span><br><span>    </span><span class="ͼt">task</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Task</span><span>(</span><span class="ͼr">"Walk"</span><span>, </span><span class="ͼr">"08:00"</span><span>, </span><span class="ͼr">"daily"</span><span>)</span><br><span>    </span><span class="ͼt">pet</span><span class="ͼn">.</span><span>add_task(</span><span class="ͼt">task</span><span>)</span><br><br><span>    </span><span class="ͼt">task</span><span class="ͼn">.</span><span>mark_complete()</span><br><br><span>    </span><span class="ͼt">scheduler</span><span> </span><span class="ͼn">=</span><span> </span><span class="ͼt">Scheduler</span><span>()</span><br><span>    </span><span class="ͼt">scheduler</span><span class="ͼn">.</span><span>handle_recurrence(</span><span class="ͼt">pet</span><span>)</span><br><br><span>    </span><span class="ͼn">assert</span><span> </span><span class="ͼt">len</span><span>(</span><span class="ͼt">pet</span><span class="ͼn">.</span><span>tasks) </span><span class="ͼn">==</span><span> </span><span class="ͼq">2</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
