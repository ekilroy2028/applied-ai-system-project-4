d({</span><br><span>            </span><span class="ͼr">"Time"</span><span>: </span><span class="ͼt">task</span><span class="ͼn">.</span><span>time,</span><br><span>            </span><span class="ͼr">"Pet"</span><span>: </span><span class="ͼt">pet_name</span><span>,</span><br><span>            </span><span class="ͼr">"Task"</span><span>: </span><span class="ͼt">task</span><span class="ͼn">.</span><span>description,</span><br><span>            </span><span class="ͼr">"Done"</span><span>: </span><span class="ͼr">"✅"</span><span> </span><span class="ͼn">if</span><span> </span><span class="ͼt">task</span><span class="ͼn">.</span><span>completed </span><span class="ͼn">else</span><span> </span><span class="ͼr">"❌"</span><br><span>        })</span><br><br><span>    </span><span class="ͼt">st</span><span class="ͼn">.</span><span>table(</span><span class="ͼt">display_data</span><span>)</span><br><span class="ͼn">else</span><span>:</span><br><span>    </span><span class="ͼt">st</span><span class="ͼn">.</span><span>info(</span><span class="ͼr">"No tasks scheduled yet."</span><span>)</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
