def _disney(name, description, character_type, debut_year, studio,
            series_list, eras, wiki_slug,
            extra_creators=None,
            origin="Los Angeles, California, USA — Walt Disney Studios, Burbank"):
    c = Cartoon(
        name=name,
        description=description,
        character_type=character_type,
        country_of_origin="USA",
        debut_year=debut_year,
    )
    c.original_studio = studio
    c.add_creator(WALT)
    if extra_creators:
        for ec in extra_creators:
            c.add_creator(ec)
    for s in series_list:
        c.add_series(s)
    for i, (owner, y0, y1, method) in enumerate(DISNEY_OWNERSHIP):
        is_cur = (i == len(DISNEY_OWNERSHIP) - 1)
        c.add_ownership_record(OwnershipRecord(owner, y0, y1, method, is_current_owner=is_cur))
    for era in eras:
        c.add_era(era)
    c.wiki_url = f"https://en.wikipedia.org/wiki/{wiki_slug}"
    c.origin_location = origin
    return c


