def test_add_ownership_record(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, None, "original creation", is_current_owner=True))
    assert len(simple_cartoon.ownership_history) == 1


def test_current_owner_flagged_correctly(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, 1980, "original creation"))
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner B", 1980, None, "purchase", is_current_owner=True))
    assert simple_cartoon.current_owner.owner_name == "Owner B"


def test_new_current_owner_deflagged_previous(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, 1980, "original creation", is_current_owner=True))
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner B", 1980, None, "purchase", is_current_owner=True))
    # Owner A should no longer be flagged
    owner_a = next(o for o in simple_cartoon.ownership_history if o.owner_name == "Owner A")
    assert not owner_a.is_current_owner


def test_original_owner_is_earliest(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner B", 1980, None, "purchase", is_current_owner=True))
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, 1980, "original creation"))
    assert simple_cartoon.original_owner.owner_name == "Owner A"


def test_ownership_changed_true_when_different(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, 1980, "original creation"))
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner B", 1980, None, "purchase", is_current_owner=True))
    assert simple_cartoon.ownership_changed is True


def test_ownership_changed_false_when_same(simple_cartoon):
    simple_cartoon.add_ownership_record(OwnershipRecord("Owner A", 1950, None, "original creation", is_current_owner=True))
    assert simple_cartoon.ownership_changed is False


