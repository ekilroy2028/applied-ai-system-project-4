def test_sort_by_debut_descending(full_library):
    analyzer = CartoonAnalyzer(full_library)
    sorted_list = analyzer.sort_by_debut(ascending=False)
    years = [c.debut_year for c in sorted_list]
    assert years == sorted(years, reverse=True)


def test_copyright_summary_totals(full_library):
    analyzer = CartoonAnalyzer(full_library)
    summary = analyzer.get_copyright_summary()
    assert summary["total"] == summary["public_domain"] + summary["protected"]


def test_flag_approaching_returns_only_protected(full_library):
    analyzer = CartoonAnalyzer(full_library)
    approaching = analyzer.flag_approaching_public_domain(within_years=50)
    assert all(not c.is_public_domain for c in approaching)


def test_detect_series_overlap():
    lib = Library()
    c = Cartoon("Multi-Series Toon", "d", "animal", debut_year=1940)
    c.add_series(Series("Series A", 1940, 1970, "Studio"))
    c.add_series(Series("Series B", 1960, 1975, "Studio"))  # overlaps with A
    lib.add_cartoon(c)
    analyzer = CartoonAnalyzer(lib)
    overlaps = analyzer.detect_series_overlap(c)
    assert len(overlaps) > 0


def test_detect_series_no_overlap():
    lib = Library()
    c = Cartoon("Sequential Toon", "d", "animal", debut_year=1940)
    c.add_series(Series("Series A", 1940, 1960, "Studio"))
    c.add_series(Series("Series B", 1965, 1975, "Studio"))  # no overlap
    lib.add_cartoon(c)
    analyzer = CartoonAnalyzer(lib)
    overlaps = analyzer.detect_series_overlap(c)
    assert len(overlaps) == 0


