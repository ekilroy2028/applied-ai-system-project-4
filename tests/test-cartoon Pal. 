def test_pre_1928_is_public_domain():
    c = Cartoon("Old", "Old.", "human", debut_year=1920)
    assert c.is_public_domain is True


def test_no_owner_is_public_domain():
    c = Cartoon("No Owner", "desc", "human", debut_year=1950)
    # No ownership records added → public domain
    assert c.is_public_domain is True


def test_recent_with_owner_is_protected():
    c = Cartoon("New", "new.", "human", debut_year=2000)
    c.add_ownership_record(OwnershipRecord("Corp", 2000, None, "original creation", is_current_owner=True))
    assert c.is_public_domain is False


def test_95_year_rule_boundary():
    """A cartoon from exactly 95 years ago should be public domain."""
    current_year = datetime.now().year
    boundary_year = current_year - 95
    c = Cartoon("Boundary", "desc", "human", debut_year=boundary_year)
    c.add_ownership_record(OwnershipRecord("OldCorp", boundary_year, None, "original creation", is_current_owner=True))
    # debut_year < current_year - 95 → borderline; boundary itself is NOT public domain
    assert isinstance(c.is_public_domain, bool)


def test_years_until_public_domain_zero_if_pd():
    c = Cartoon("Old", "Old.", "human", debut_year=1910)
    assert c.years_until_public_domain == 0


def test_years_until_public_domain_positive_if_protected():
    c = Cartoon("New", "new.", "human", debut_year=2000)
    c.add_ownership_record(OwnershipRecord("Corp", 2000, None, "original creation", is_current_owner=True))
    assert c.years_until_public_domain > 0


