def build_few_shot_prompt(cartoon: Cartoon) -> str:
    """Build a few-shot prompt with CartoonPal's curated examples."""

    # Select the most relevant examples based on the cartoon's profile
    selected_examples = []

    # Always include a public domain example if cartoon is PD, or protected if not
    if cartoon.is_public_domain:
        selected_examples.append(FEW_SHOT_EXAMPLES[0])  # Felix — public domain
    else:
        selected_examples.append(FEW_SHOT_EXAMPLES[1])  # Bugs — protected

    # Add international example if non-US
    if cartoon.country_of_origin != "USA":
        selected_examples.append(FEW_SHOT_EXAMPLES[2])  # Goku — international

    # Add approaching PD example if within 10 years
    elif not cartoon.is_public_domain and cartoon.years_until_public_domain <= 10:
        selected_examples.append(FEW_SHOT_EXAMPLES[3])  # Goofy — approaching PD

    # Add complex ownership example if many ownership transfers
    elif len(cartoon.ownership_history) > 3:
        selected_examples.append(FEW_SHOT_EXAMPLES[4])  # Superman — complex ownership

    # Build the examples block
    examples_block = ""
    for i, ex in enumerate(selected_examples, 1):
        examples_block += (
            f"EXAMPLE {i} ({ex['scenario']}):\n"
            f"INPUT: {ex['input']}\n"
            f"OUTPUT:\n{ex['output']}\n\n"
            f"{'─'*60}\n\n"
        )

    # Build the actual cartoon's input summary
    orig = cartoon.original_owner
    curr = cartoon.current_owner
    ownership_summary = " | ".join([
        f"{r.owner_name} ({r.year_acquired}-{r.year_relinquished or 'present'})"
        for r in cartoon.ownership_history
    ])
    creators_text = ", ".join(c.full_name for c in cartoon.creators) or "Unknown"
    pd_status = "PUBLIC DOMAIN" if cartoon.is_public_domain else "PROTECTED"
    yrs = cartoon.years_until_public_domain
    yrs_text = f"({yrs} years remaining)" if yrs > 0 else "(already public domain)"

    cartoon_input = (
        f"Character: {cartoon.name} | Debut: {cartoon.debut_year} | "
        f"Country: {cartoon.country_of_origin} | "
        f"Creators: {creators_text} | "
        f"Status: {pd_status} {yrs_text} | "
        f"Ownership: {ownership_summary}"
    )

    prompt = (
        "You are a CartoonPal copyright analyst. You write structured copyright determinations "
        "following the exact format shown in the examples below.\n\n"
        "IMPORTANT: Always follow this exact output format:\n"
        "STATUS: [public domain or protected + who owns it]\n"
        "BASIS: [the specific legal reason — cite the 95-year rule, life+years, etc.]\n"
        "NUANCE: [any complications, trademark vs copyright, international law, creator rights]\n"
        "PRACTICAL GUIDANCE: [what someone who wants to USE this character should know]\n"
        "CONFIDENCE: HIGH, MEDIUM, or LOW\n\n"
        f"CALIBRATION EXAMPLES:\n\n{examples_block}"
        f"NOW ANALYZE THIS CHARACTER:\n"
        f"INPUT: {cartoon_input}\n\n"
        "OUTPUT:"
    )

    return prompt


def run_few_shot_analysis(cartoon: Cartoon) -> dict:
    """
    Run few-shot specialized copyright analysis.

    Uses curated CartoonPal examples to calibrate Claude's output
    to a consistent, structured, domain-specific format.

    Returns:
        dict with keys: success, analysis, confidence, examples_used, format_sections
    """
    try:
        import anthropic
    except ImportError:
        return {
            "success": False,
            "analysis": "anthropic package not installed. Run: pip3 install anthropic",
            "confidence": "ERROR",
            "examples_used": 0,
            "format_sections": {}
        }

    try:
        client = anthropic.Anthropic()
        prompt = build_few_shot_prompt(cartoon)

        # Count how many examples were selected
        examples_used = prompt.count("EXAMPLE ")

        response = client.messages.create(
            model="claude-sonnet-4-5",
            max_tokens=500,
            messages=[{"role": "user", "content": prompt}]
        )
        analysis = response.content[0].text.strip()

        # Parse confidence
        confidence = "MEDIUM"
        upper = analysis.upper()
        if "CONFIDENCE: HIGH" in upper:
            confidence = "HIGH"
        elif "CONFIDENCE: LOW" in upper:
            confidence = "LOW"

        # Parse structured sections
        sections = {}
        for section in ["STATUS", "BASIS", "NUANCE", "PRACTICAL GUIDANCE", "CONFIDENCE"]:
            if f"{section}:" in analysis:
                start = analysis.find(f"{section}:") + len(section) + 1
                # Find the next section
                next_section_pos = len(analysis)
                for other in ["STATUS:", "BASIS:", "NUANCE:", "PRACTICAL GUIDANCE:", "CONFIDENCE:"]:
                    pos = analysis.find(other, start)
                    if pos != -1 and pos < next_section_pos and other != f"{section}:":
                        next_section_pos = pos
                sections[section] = analysis[start:next_section_pos].strip()

        log.info("Few-shot analysis complete for %s — confidence: %s, examples used: %d",
                 cartoon.name, confidence, examples_used)

        return {
            "success": True,
            "analysis": analysis,
            "confidence": confidence,
            "examples_used": examples_used,
            "format_sections": sections
        }

    except Exception as e:
        log.error("Few-shot analysis failed for %s: %s", cartoon.name, e)
        return {
            "success": False,
            "analysis": f"Analysis failed: {e}. Check ANTHROPIC_API_KEY.",
            "confidence": "ERROR",
            "examples_used": 0,
            "format_sections": {}
        }